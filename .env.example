# Copia este fichero a .env y rellena tu clave de football-data.org
# En Netlify: Site settings → Environment variables
VITE_FOOTBALL_API_KEY=tu_clave_aqui

# Intervalo de refresco en ms (por defecto 2 minutos)
VITE_REFRESH_INTERVAL_MS=120000

# Días hacia atrás/adelante que se muestran en la pantalla de partidos
VITE_MATCHDAY_WINDOW_DAYS=3
